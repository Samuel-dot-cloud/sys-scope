{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the SysScope desktop windows",
  "windows": ["main", "about"],
  "permissions": [
    "core:default",
    "core:app:allow-set-app-theme",
    "autostart:default",
    "dialog:allow-ask",
    "dialog:allow-message",
    "process:allow-restart",
    "updater:default"
  ]
}
